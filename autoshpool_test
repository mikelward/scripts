  if grep -q "shpool attach -d . 2" "$HOME/.shpool_calls" 2>/dev/null; then
    echo "  FAIL: should not have retried with session 2"
    echo "  calls: $(cat "$HOME/.shpool_calls" 2>/dev/null)"
    return 1
  fi
}

