  printf 'abcdef Something\n123456 Other\n' > "$d/.unmerged"
  add_shpool 1000
  add_shell 2001 1000 "$d" 7
  run_autoshpool switch abcdef
  assert_status 0
  assert_switch_file 7
}

test_switch_unmerged_matches_whole_word() {
