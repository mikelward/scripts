work   2025-01-01T00:00:00Z   disconnected
EOF
  add_shpool 1000
  add_shell 2001 1000 "/home/u/work/foo" 5
  run_autoshpool switch work
  assert_status 0
  assert_switch_file work
}

test_switch_no_match_uses_arg() {
