#!/bin/sh

format="%a %H:%M"
#format="%a %I:%M %p"
when="$1"
localzone=${2:-$(date -d "$when" '+%z')}

# GNU date rejects a date-only string followed by a zone offset
# (e.g. "2026-06-10 +0000"); add an explicit midnight time.
if test -n "$when" && ! date -d "$when $localzone" >/dev/null 2>&1; then
	when="$when 00:00"
fi

IFS='|'
while read timezone description
do
	if test -n "$timezone"
	then
		continent=${timezone%/*}
		city=${timezone#*/}
		city=$(echo "$city" | tr '_' ' ')
		if test -z "$description"
		then
			description=$city
		fi
		time=$(TZ="$timezone" date ${when:+-d "$when $localzone"} +"$format")
		printf "%-15s %9s\n" "$description" "$time"
	fi
done < "$HOME/.timezones"

