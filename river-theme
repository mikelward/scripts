#!/bin/sh
# river-theme -- time-of-day light/dark theming for the river desktop.
#
# Light mode from 07:00 to 19:00, dark mode outside that. Applies a single
# coherent palette to every surface:
#   - river window borders            (riverctl, at runtime)
#   - Waybar and swaync               (generated theme.css they @import,
#                                      then a live reload)
#   - fuzzel and swaylock             (colour flags, via the `menu` and
#                                      `lock` subcommands used by the binds)
#
# The current mode is recorded in a small state file so the launcher and
# lock wrappers stay in sync between full re-applies.
#
# Usage:
#   river-theme apply [light|dark|auto]   apply once (auto = by clock; default)
#   river-theme toggle                    flip light<->dark and apply
#   river-theme watch                     apply now, then flip at 07:00/19:00
#   river-theme menu [-- fuzzel args...]  launch fuzzel themed for current mode
#   river-theme lock [-- swaylock args]   launch swaylock themed for current mode
#   river-theme mode                      print current mode (light|dark)
#
# Designed to degrade gracefully: riverctl / waybar / swaync / fuzzel /
# swaylock each may be absent and the relevant step is simply skipped.
#
# Testing hook: set RIVER_THEME_FORCE_HOUR to pin the "current hour" so
# the light/dark boundary logic can be exercised deterministically.

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
STATE_DIR="$CACHE_HOME/river-theme"
STATE_FILE="$STATE_DIR/mode"

# Light mode covers hours [DAY_START, DAY_END): 07:00 up to (not incl) 19:00.
DAY_START=7
DAY_END=19

# --- Palettes ---------------------------------------------------------------
#
# Each palette exports the same set of names. Colours are plain rrggbb.
# Dark matches the rest of the repo (accent amber). Light is a classic
# grey desktop with a readable blue accent.

set_palette() {
	case "$1" in
	light)
		BG=ececec
		BG_ALT=dcdcdc
		FG=202020
		MUTED=606060
		ACCENT=2c6cbf
		ALERT=c0392b
		BORDER_UNFOCUSED=b0b0b0
		;;
	*) # dark
		BG=222222
		BG_ALT=2e2e2e
		FG=dfdfdf
		MUTED=8a8a8a
		ACCENT=ffb52a
		ALERT=e60053
		BORDER_UNFOCUSED=444444
		;;
	esac
}

# --- Mode selection ---------------------------------------------------------

# Strip a single leading zero so a value like 08/09 isn't treated as an
# invalid octal number by POSIX $(( )). "00" -> "0", "" -> "0".
dec() {
	v="${1#0}"
	echo "${v:-0}"
}

# Print "light" or "dark" for the current hour.
mode_for_clock() {
	h="$(dec "${RIVER_THEME_FORCE_HOUR:-$(date +%H)}")"
	if test "$h" -ge "$DAY_START" && test "$h" -lt "$DAY_END"; then
		echo light
	else
		echo dark
	fi
}

current_mode() {
	if test -r "$STATE_FILE"; then
		cat "$STATE_FILE"
	else
		mode_for_clock
	fi
}

# --- Apply ------------------------------------------------------------------

# Write the Waybar/swaync colour file. Both style.css files @import
# "theme.css" from their own config dir, so this is the single source of
# truth for their palette.
write_css() {
	dir="$1"
	test -d "$dir" || return 0
	cat >"$dir/theme.css" <<CSS
/* Generated by river-theme -- do not edit; regenerated on theme change. */
@define-color bg      #$BG;
@define-color bg-alt  #$BG_ALT;
@define-color fg      #$FG;
@define-color muted   #$MUTED;
@define-color accent  #$ACCENT;
@define-color alert   #$ALERT;
CSS
}

apply() {
	mode="$1"
	set_palette "$mode"

	# Record mode for the menu/lock wrappers.
	mkdir -p "$STATE_DIR"
	echo "$mode" >"$STATE_FILE"

	# river borders (runtime).
	if command -v riverctl >/dev/null 2>&1; then
		riverctl border-color-focused "0x$ACCENT" 2>/dev/null || true
		riverctl border-color-unfocused "0x$BORDER_UNFOCUSED" 2>/dev/null || true
		riverctl border-color-urgent "0x$ALERT" 2>/dev/null || true
	fi

	# Waybar + swaync palettes, then live-reload each if running.
	write_css "$CONFIG_HOME/waybar"
	write_css "$CONFIG_HOME/swaync"
	# Waybar reloads config+style on SIGUSR2; no-op if it isn't running.
	pkill -USR2 -x waybar 2>/dev/null || true
	if command -v swaync-client >/dev/null 2>&1; then
		swaync-client --reload-css >/dev/null 2>&1 || true
	fi

	printf 'river-theme: applied %s mode\n' "$mode" >&2
}

# --- Subcommand wrappers ----------------------------------------------------

# fuzzel themed for the current mode. Layout/font/radius come from the
# repo fuzzel.ini; colours are overridden on the command line so a single
# static config serves both themes.
run_menu() {
	mode="$(current_mode)"
	set_palette "$mode"
	# fuzzel option names per fuzzel(1): the background flag is bare
	# --background (NOT --background-color); the rest are --<thing>-color.
	# Passing an unknown option makes fuzzel exit before opening, so only
	# documented flags are used here.
	exec fuzzel \
		--config "$CONFIG_HOME/fuzzel/fuzzel.ini" \
		--background "${BG}f2" \
		--text-color "${FG}ff" \
		--match-color "${ACCENT}ff" \
		--selection-color "${ACCENT}ff" \
		--selection-text-color "${BG}ff" \
		--border-color "${ACCENT}ff" \
		"$@"
}

# swaylock themed for the current mode. Non-colour options (indicator,
# ignore-empty-password, ...) come from ~/.config/swaylock/config; -f
# daemonizes after locking so this returns promptly (safe for
# swayidle before-sleep).
run_lock() {
	mode="$(current_mode)"
	set_palette "$mode"
	exec swaylock -f \
		--color "$BG" \
		--inside-color "$BG_ALT" \
		--ring-color "$BORDER_UNFOCUSED" \
		--key-hl-color "$ACCENT" \
		--ring-ver-color "$ACCENT" \
		--ring-clear-color "$ACCENT" \
		--ring-wrong-color "$ALERT" \
		--bs-hl-color "$ALERT" \
		--text-color "$FG" \
		"$@"
}

# --- Watch loop -------------------------------------------------------------

# Seconds from now until the next 07:00/19:00 boundary.
seconds_until_next_boundary() {
	h="$(dec "$(date +%H)")"
	m="$(dec "$(date +%M)")"
	s="$(dec "$(date +%S)")"
	now=$((h * 3600 + m * 60 + s))
	start=$((DAY_START * 3600))
	end=$((DAY_END * 3600))
	if test "$now" -lt "$start"; then
		echo $((start - now))
	elif test "$now" -lt "$end"; then
		echo $((end - now))
	else
		echo $((start + 86400 - now))
	fi
}

watch() {
	while true; do
		apply "$(mode_for_clock)"
		# +2s guard so we wake just after the boundary, not on it.
		sleep "$(($(seconds_until_next_boundary) + 2))"
	done
}

# --- Dispatch ---------------------------------------------------------------

cmd="${1:-apply}"
test $# -gt 0 && shift

case "$cmd" in
apply)
	want="${1:-auto}"
	case "$want" in
	light | dark) apply "$want" ;;
	auto | "") apply "$(mode_for_clock)" ;;
	*)
		printf 'river-theme: unknown mode "%s"\n' "$want" >&2
		exit 1
		;;
	esac
	;;
toggle)
	if test "$(current_mode)" = light; then
		apply dark
	else
		apply light
	fi
	;;
watch) watch ;;
menu)
	# Allow "river-theme menu -- <fuzzel args>".
	test "${1:-}" = "--" && shift
	run_menu "$@"
	;;
lock)
	test "${1:-}" = "--" && shift
	run_lock "$@"
	;;
mode) current_mode ;;
-h | --help)
	sed -n '2,30p' "$0"
	;;
*)
	printf 'river-theme: unknown command "%s" (try --help)\n' "$cmd" >&2
	exit 1
	;;
esac
