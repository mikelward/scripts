#!/bin/bash
. "$HOME"/.shrc
usage() {
  cat <<EOF 1>&2
Usage: $scriptname [-d <delay>] [-h] [-w]
       $scriptname [--delay <delay>] [--help] [--window]
EOF
}

scriptname=${0##*/}
delay=0
typeset -a args=()
window=false

while test $# -gt 0; do
  case "$1" in
  -d|--delay)
    if test $# -lt 2; then
      echo "Option $1 requires an argument" 1>&2
      usage
      exit 2
    fi
    delay=$2
    shift
    ;;
  --delay=*)
    delay=${1#*=}
    ;;
  -w|--window)
    window=true
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  --)
    shift
    break
    ;;
  -*)
    echo "Invalid option $1" 1>&2
    usage
    exit 2
    ;;
  *)
    break
    ;;
  esac
  shift
done

cd "$HOME/Pictures" || exit 1

sleep $delay

if $window; then
  wid=$(xdotool selectwindow)
  args+=("-w" "$wid")
fi

exec scrot "${args[@]}"
