#!/bin/sh
# Tests for mdf

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MDF="$SCRIPT_DIR/mdf"
TESTS_RUN=0
TESTS_PASSED=0
TESTS_FAILED=0

# run_mdf <input> [args...]: feed <input> on stdin, capture stdout and status.
# Note: command substitution strips trailing newlines from both the captured
# output and the expected value, so comparisons stay consistent.
run_mdf() {
    input="$1"
    shift
    set +e
    output="$(printf '%s' "$input" | "$MDF" "$@" 2>&1)"
    status=$?
    set -e
}

assert_status() {
    if test "$status" -ne "$1"; then
        echo "  FAIL: expected exit status $1, got $status"
        echo "  output: $output"
        TEST_FAILED=1
        return 1
    fi
}

assert_output_equals() {
    expected="$1"
    if test "$output" != "$expected"; then
        echo "  FAIL: output mismatch"
        echo "  expected: $(printf '%s' "$expected" | sed -n l)"
        echo "  actual:   $(printf '%s' "$output" | sed -n l)"
        TEST_FAILED=1
        return 1
    fi
}

assert_output_contains() {
    case "$output" in
        *"$1"*) ;;
        *)
            echo "  FAIL: output does not contain '$1'"
            echo "  output: $output"
            TEST_FAILED=1
            return 1
            ;;
    esac
}

run_test() {
    name="$1"
    func="$2"
    TESTS_RUN=$((TESTS_RUN + 1))
    # TEST_FAILED catches asserts that fail mid-test: running "$func" as an
    # `if` condition disables `set -e` inside it, so a failed assert that is
    # not the last statement would otherwise be ignored.
    TEST_FAILED=
    if "$func" && test -z "$TEST_FAILED"; then
        echo "ok $TESTS_RUN $name"
        TESTS_PASSED=$((TESTS_PASSED + 1))
    else
        echo "not ok $TESTS_RUN $name"
        TESTS_FAILED=$((TESTS_FAILED + 1))
    fi
}

# --- dedent tests ---

test_dedent_strips_common_prefix() {
    run_mdf "    hello
    world"
    assert_status 0 &&
    assert_output_equals "hello
world"
}

test_dedent_preserves_nesting() {
    run_mdf "    one
      nested
    two"
    assert_status 0 &&
    assert_output_equals "one
  nested
two"
}

test_dedent_leaves_unindented_alone() {
    run_mdf "no indent
here"
    assert_status 0 &&
    assert_output_equals "no indent
here"
}

# --- bullet conversion tests ---

test_converts_dot_bullet() {
    run_mdf "• one
• two"
    assert_status 0 &&
    assert_output_equals "* one
* two"
}

test_converts_various_glyphs() {
    run_mdf "◦ circle
▪ square
– en dash
— em dash"
    assert_status 0 &&
    assert_output_equals "* circle
* square
* en dash
* em dash"
}

test_dedent_and_bullets_together() {
    run_mdf "    • one
    • two
      ◦ nested"
    assert_status 0 &&
    assert_output_equals "* one
* two
  * nested"
}

test_existing_markers_untouched() {
    run_mdf "- dash
* star
+ plus"
    assert_status 0 &&
    assert_output_equals "- dash
* star
+ plus"
}

test_midline_glyph_not_touched() {
    run_mdf "this — is an aside
a•b joined"
    assert_status 0 &&
    assert_output_equals "this — is an aside
a•b joined"
}

test_blank_lines_preserved() {
    run_mdf "• one

• two"
    assert_status 0 &&
    assert_output_equals "* one

* two"
}

test_custom_marker() {
    run_mdf "• one" --marker -
    assert_status 0 &&
    assert_output_equals "- one"
}

test_converts_nbsp_separator() {
    # bullet followed by a non-breaking space (common in rich-text paste)
    run_mdf "$(printf '\342\200\242\302\240item')"
    assert_status 0 &&
    assert_output_equals "* item"
}

# --- cli tests ---

test_help_exits_zero() {
    run_mdf "" -h
    assert_status 0 &&
    assert_output_contains "usage"
}

test_missing_file_errors() {
    set +e
    output="$("$MDF" /no/such/file 2>&1)"
    status=$?
    set -e
    assert_status 1 &&
    assert_output_contains "mdf:"
}

test_reads_file_argument() {
    tmp="$(mktemp)"
    printf '    • from file' > "$tmp"
    set +e
    output="$("$MDF" "$tmp" 2>&1)"
    status=$?
    set -e
    rm -f "$tmp"
    assert_status 0 &&
    assert_output_equals "* from file"
}

# --- run ---

run_test "dedent strips common prefix" test_dedent_strips_common_prefix
run_test "dedent preserves nesting" test_dedent_preserves_nesting
run_test "dedent leaves unindented text alone" test_dedent_leaves_unindented_alone
run_test "converts bullet dot" test_converts_dot_bullet
run_test "converts various glyphs" test_converts_various_glyphs
run_test "dedent and bullets together" test_dedent_and_bullets_together
run_test "existing markers untouched" test_existing_markers_untouched
run_test "mid-line glyph not touched" test_midline_glyph_not_touched
run_test "blank lines preserved" test_blank_lines_preserved
run_test "custom marker" test_custom_marker
run_test "converts nbsp separator" test_converts_nbsp_separator
run_test "help exits zero" test_help_exits_zero
run_test "missing file errors" test_missing_file_errors
run_test "reads file argument" test_reads_file_argument

echo
echo "$TESTS_RUN tests, $TESTS_PASSED passed, $TESTS_FAILED failed"
test "$TESTS_FAILED" -eq 0
