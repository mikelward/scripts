#!/bin/sh
# Configure KDE Plasma 6 desktop environment.
#
# Sets up:
# - Krohnkite tiling window manager
# - Focus follows mouse
# - Window management and desktop switching keybindings
# - Application launch shortcuts (browser, terminal, music)
#
# Requires: git, npm, kpackagetool6, kwriteconfig6
# Optional: go-task (preferred build tool), p7zip
#
# Usage:
#     setup-kde

set -e

KROHNKITE_REPO="https://codeberg.org/anametologin/Krohnkite.git"
KROHNKITE_DIR="${TMPDIR:-/tmp}/krohnkite-$$"

info() {
    printf "%s\n" "$*"
}

warn() {
    printf "Warning: %s\n" "$*" >&2
}

error() {
    printf "Error: %s\n" "$*" >&2
    exit 1
}

cleanup() {
    rm -rf "$KROHNKITE_DIR"
}
trap cleanup EXIT

# --- Check prerequisites ---

command -v git >/dev/null 2>&1 || error "git is required"
command -v npm >/dev/null 2>&1 || error "npm is required (to build Krohnkite)"
command -v kpackagetool6 >/dev/null 2>&1 || error "kpackagetool6 is required (KDE Plasma 6)"
command -v kwriteconfig6 >/dev/null 2>&1 || error "kwriteconfig6 is required (KDE Plasma 6)"

# --- Install Krohnkite ---

install_krohnkite() {
    info "Cloning Krohnkite"
    git clone --depth 1 "$KROHNKITE_REPO" "$KROHNKITE_DIR"

    cd "$KROHNKITE_DIR"

    # Build using go-task (preferred) or make (fallback)
    if command -v go-task >/dev/null 2>&1; then
        info "Building Krohnkite with go-task"
        go-task package
    elif test -f Makefile; then
        info "Building Krohnkite with make"
        make
    else
        info "Building Krohnkite with npm"
        npm install && npm run build
    fi

    # Find the built .kwinscript file, or a directory containing metadata.json
    kwinscript=$(find . -name '*.kwinscript' -print -quit)
    if test -n "$kwinscript"; then
        info "Installing Krohnkite from $kwinscript"
        kpackagetool6 -t KWin/Script -u "$kwinscript" 2>/dev/null ||
            kpackagetool6 -t KWin/Script -i "$kwinscript"
    else
        pkgdir=$(find . \( -name metadata.json -o -name metadata.desktop \) \
            -printf '%h\n' -quit 2>/dev/null)
        if test -n "$pkgdir"; then
            info "Installing Krohnkite from $pkgdir"
            kpackagetool6 -t KWin/Script -u "$pkgdir" 2>/dev/null ||
                kpackagetool6 -t KWin/Script -i "$pkgdir"
        else
            error "Could not find installable Krohnkite package"
        fi
    fi
}

# --- Enable Krohnkite ---

enable_krohnkite() {
    info "Enabling Krohnkite plugin"
    kwriteconfig6 --file kwinrc --group Plugins --key krohnkiteEnabled true
}

# --- Configure Krohnkite ---

# Pick the layouts available in the cycle and their order. A *LayoutOrder
# value of 0 removes the layout from the cycle entirely (Krohnkite source:
# KWinConfig.getSortedLayouts skips orders that validate to 0).
configure_krohnkite() {
    info "Configuring Krohnkite layouts: Tile, ThreeColumn, Columns, Monocle"
    set_layout_order() {
        kwriteconfig6 --file kwinrc --group Script-krohnkite --key "$1" "$2"
    }
    # Columns layout has its own enable flag in addition to the order.
    kwriteconfig6 --file kwinrc --group Script-krohnkite --key enableColumnsLayout true
    set_layout_order tileLayoutOrder 1
    set_layout_order threeColumnLayoutOrder 2
    set_layout_order columnsLayoutOrder 3
    set_layout_order monocleLayoutOrder 4
    # Everything else: removed from the cycle.
    for key in spiralLayoutOrder quarterLayoutOrder stackedLayoutOrder \
               spreadLayoutOrder floatingLayoutOrder stairLayoutOrder \
               binaryTreeLayoutOrder cascadeLayoutOrder; do
        set_layout_order "$key" 0
    done
}

# --- Focus follows mouse ---

configure_focus_follows_mouse() {
    info "Enabling focus follows mouse"
    kwriteconfig6 --file kwinrc --group Windows --key FocusPolicy FocusUnderMouse
    kwriteconfig6 --file kwinrc --group Windows --key NextFocusPrefersMouse true
}

# --- Configure virtual desktops ---

configure_desktops() {
    info "Configuring 9 virtual desktops"
    kwriteconfig6 --file kwinrc --group Desktops --key Number 9
    kwriteconfig6 --file kwinrc --group Desktops --key Rows 1
}

# --- Configure keybindings ---

set_shortcut() {
    action="$1"
    shortcut="$2"
    kwriteconfig6 --file kglobalshortcutsrc --group kwin \
        --key "$action" "$shortcut,none,$action"
}

unbind_shortcut() {
    action="$1"
    kwriteconfig6 --file kglobalshortcutsrc --group kwin \
        --key "$action" "none,none,$action"
}

unbind_shortcut_in() {
    group="$1"
    action="$2"
    kwriteconfig6 --file kglobalshortcutsrc --group "$group" \
        --key "$action" "none,none,$action"
}

unbind_all_krohnkite_shortcuts() {
    config_file="${XDG_CONFIG_HOME:-$HOME/.config}/kglobalshortcutsrc"
    test -f "$config_file" || return 0

    in_kwin=false
    while IFS= read -r line; do
        case "$line" in
            "[kwin]")
                in_kwin=true
                ;;
            "["*)
                in_kwin=false
                ;;
            *)
                if $in_kwin; then
                    case "$line" in
                        "Krohnkite: "*)
                            action="${line%%=*}"
                            unbind_shortcut "$action"
                            ;;
                    esac
                fi
                ;;
        esac
    done < "$config_file"
}

# --- Application launch shortcuts ---

add_app_shortcut() {
    name="$1"
    command="$2"
    shortcut="$3"
    desktop_file="$4"

    desktop_dir="$HOME/.local/share/applications"
    mkdir -p "$desktop_dir"

    # X-KDE-GlobalAccel-CommandShortcut=true is what flags this .desktop as
    # a launch-shortcut component; without it, kglobalaccel won't register
    # the _launch entry, the shortcut never grabs, and the keypress falls
    # through to the focused window.
    cat > "$desktop_dir/$desktop_file" <<EOF
[Desktop Entry]
Type=Application
Name=$name
Exec=$command
NoDisplay=true
StartupNotify=false
X-KDE-GlobalAccel-CommandShortcut=true
EOF

    # Nested group [services][foo.desktop] is what kglobalaccel reads for
    # desktop-file launch shortcuts; a top-level [foo.desktop] group is
    # silently ignored. The value is just the shortcut — the ",default,name"
    # suffix used for [kwin] actions doesn't apply to launch shortcuts.
    kwriteconfig6 --file kglobalshortcutsrc \
        --group services --group "$desktop_file" \
        --key _launch "$shortcut"
}

# An earlier version of this script wrote app-launch shortcuts under a
# top-level [scripts-foo.desktop] group, which kglobalaccel ignores. Strip
# any such stale groups before we rewrite them under [services].
remove_stale_app_shortcut_groups() {
    config_file="${XDG_CONFIG_HOME:-$HOME/.config}/kglobalshortcutsrc"
    test -f "$config_file" || return 0
    python3 - "$config_file" <<'PY'
import re, sys, pathlib
p = pathlib.Path(sys.argv[1])
text = p.read_text()
new = re.sub(r'(?ms)^\[scripts-[^\]]+\.desktop\]\n(?:(?!^\[).*\n?)*', '', text)
if new != text:
    p.write_text(new)
PY
}

configure_app_shortcuts() {
    info "Configuring application shortcuts"

    remove_stale_app_shortcut_groups

    scripts="$HOME/scripts"
    add_app_shortcut "Browser 1" "$scripts/browser1" "Meta+G" "scripts-browser1.desktop"
    add_app_shortcut "Browser 2" "$scripts/browser2" "Meta+H" "scripts-browser2.desktop"
    add_app_shortcut "Terminal" "$scripts/terminal" "Meta+T" "scripts-terminal.desktop"
    add_app_shortcut "Terminal on Workstation" "$scripts/terminal_on_workstation" "Meta+W" "scripts-terminal-workstation.desktop"
    add_app_shortcut "Music" "$scripts/music" "Meta+Y" "scripts-music.desktop"
}

configure_keybindings() {
    info "Configuring keybindings"

    # Switch to desktop 1-9
    n=1
    while test "$n" -le 9; do
        set_shortcut "Switch to Desktop $n" "Meta+$n"
        set_shortcut "Window to Desktop $n" "Meta+Shift+$n"
        n=$((n + 1))
    done

    # Window management
    set_shortcut "Window Close" "Meta+Backspace"

    # Unbind KWin/plasmashell defaults that conflict with shortcuts we set
    # below or in configure_app_shortcuts.
    unbind_shortcut "Grid View"                                 # Meta+G -> Browser 1
    unbind_shortcut "Overview"                                  # Meta+W -> Terminal on Workstation
    unbind_shortcut "Edit Tiles"                                # Meta+T -> Terminal
    unbind_shortcut "Walk Through Windows of Current Application" # Meta+` -> Krohnkite Monocle
    n=1
    while test "$n" -le 9; do
        # Meta+1..9 -> Switch to Desktop N (plasmashell grabs these by default).
        unbind_shortcut_in plasmashell "activate task manager entry $n"
        n=$((n + 1))
    done

    # Unbind all Krohnkite shortcuts, then set only the ones we want
    unbind_all_krohnkite_shortcuts

    # Krohnkite: resize
    set_shortcut "Krohnkite: Increase" "Meta+\\\\"
    set_shortcut "Krohnkite: Decrease" "Meta+/"

    # Krohnkite: layouts
    set_shortcut "Krohnkite: Monocle Layout" "Meta+\`"
    set_shortcut "Krohnkite: Previous Layout" "Meta+,"
    set_shortcut "Krohnkite: Cycle Layout" "Meta+."

    # Krohnkite: set master
    set_shortcut "Krohnkite: Set Master" "Meta+Return"
}

# --- Reload KWin ---

reload_kwin() {
    info "Reloading KWin configuration"
    if command -v qdbus6 >/dev/null 2>&1; then
        qdbus6 org.kde.KWin /KWin reconfigure
    elif command -v qdbus >/dev/null 2>&1; then
        qdbus org.kde.KWin /KWin reconfigure
    else
        warn "qdbus not found, please restart KWin manually or log out and back in"
    fi
}

# KWin scripts don't pick up config changes on `kwin reconfigure` — the
# script keeps its original config until unloaded and reloaded. Do that
# via dbus so layout/order changes apply in the current session.
reload_krohnkite() {
    command -v qdbus6 >/dev/null 2>&1 || return 0
    main_qml="$HOME/.local/share/kwin/scripts/krohnkite/contents/ui/main.qml"
    test -f "$main_qml" || return 0
    info "Reloading Krohnkite so config changes apply"
    qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.unloadScript krohnkite >/dev/null 2>&1 || true
    qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.loadDeclarativeScript "$main_qml" krohnkite >/dev/null 2>&1 || true
    qdbus6 org.kde.KWin /Scripting org.kde.kwin.Scripting.start >/dev/null 2>&1 || true
}

# In Plasma 6, kglobalaccel is embedded in kwin — the systemd service is a
# no-op stub. On X11 we can safely replace kwin in-session to reload
# kglobalshortcutsrc; on Wayland kwin_wayland *is* the compositor, so
# replacing it kills every client. Just tell the user to log out.
reload_kglobalaccel() {
    case "$XDG_SESSION_TYPE" in
        x11)
            info "Replacing kwin_x11 so new shortcuts take effect"
            kwin_x11 --replace >/dev/null 2>&1 &
            ;;
        wayland)
            warn "on Wayland, shortcuts take effect after logging out and back in"
            ;;
        *)
            warn "unknown session type '$XDG_SESSION_TYPE'; log out and back in to pick up shortcuts"
            ;;
    esac
}

# --- Main ---

install_krohnkite
enable_krohnkite
configure_krohnkite
configure_focus_follows_mouse
configure_desktops
# Reload so Krohnkite registers its default shortcuts in kglobalshortcutsrc
reload_kwin
configure_keybindings
configure_app_shortcuts
# Rebuild service database so KDE picks up the new .desktop files
if command -v kbuildsycoca6 >/dev/null 2>&1; then
    kbuildsycoca6
fi
# Reload to apply all changes
reload_kwin
reload_krohnkite
reload_kglobalaccel

info "KDE configured successfully"
