#!/bin/bash
# Tests for the river desktop helper scripts: river-theme, river-lid,
# setup-river.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TESTS_RUN=0
TESTS_PASSED=0
TESTS_FAILED=0

RIVER_THEME="$SCRIPT_DIR/river-theme"
RIVER_LID="$SCRIPT_DIR/river-lid"
SETUP_RIVER="$SCRIPT_DIR/setup-river"

setup() {
	TEST_TMPDIR="$(mktemp -d)"
	export HOME="$TEST_TMPDIR"
	export XDG_CONFIG_HOME="$TEST_TMPDIR/.config"
	export XDG_CACHE_HOME="$TEST_TMPDIR/.cache"
	# Config dirs the css writer targets.
	mkdir -p "$XDG_CONFIG_HOME/waybar" "$XDG_CONFIG_HOME/swaync"
	# Isolated PATH: no riverctl/waybar/swaync-client, so river-theme must
	# degrade gracefully. Keep coreutils available.
	mkdir -p "$TEST_TMPDIR/bin"
	export PATH="$TEST_TMPDIR/bin:/usr/bin:/bin"
	unset RIVER_THEME_FORCE_HOUR
}

teardown() {
	rm -rf "$TEST_TMPDIR"
}

# --- assertions -------------------------------------------------------------

assert_status() {
	local expected="$1"
	if test "$status" -ne "$expected"; then
		echo "  FAIL: expected exit status $expected, got $status"
		TEST_FAILED=1
	fi
}

assert_equals() {
	local expected="$1" actual="$2"
	if test "$expected" != "$actual"; then
		echo "  FAIL: expected '$expected', got '$actual'"
		TEST_FAILED=1
	fi
}

assert_file_contains() {
	local file="$1" needle="$2"
	if ! grep -qF "$needle" "$file" 2>/dev/null; then
		echo "  FAIL: expected $file to contain '$needle'"
		TEST_FAILED=1
	fi
}

run_test() {
	local name="$1" func="$2"
	TESTS_RUN=$((TESTS_RUN + 1))
	setup
	# Run the test in the current shell so its assertions update
	# TEST_FAILED. Using it as an `if` condition disables `set -e` inside,
	# so a failing command mid-test doesn't abort the whole run. A nonzero
	# return from the function ITSELF (e.g. a failing `sh -n` that is the
	# function's last command and never touches TEST_FAILED) must also fail
	# the test -- otherwise broken scripts would still print "ok".
	TEST_FAILED=0
	if "$func"; then :; else
		echo "  FAIL: $func returned nonzero ($?)"
		TEST_FAILED=1
	fi
	teardown
	if test "$TEST_FAILED" -eq 0; then
		echo "ok $TESTS_RUN $name"
		TESTS_PASSED=$((TESTS_PASSED + 1))
	else
		echo "not ok $TESTS_RUN $name"
		TESTS_FAILED=$((TESTS_FAILED + 1))
	fi
}

# --- syntax checks ----------------------------------------------------------

test_river_theme_syntax() {
	sh -n "$RIVER_THEME"
}
test_river_lid_syntax() {
	sh -n "$RIVER_LID"
}
test_setup_river_syntax() {
	bash -n "$SETUP_RIVER"
}

# --- mode selection ---------------------------------------------------------

test_mode_midday_is_light() {
	RIVER_THEME_FORCE_HOUR=12 "$RIVER_THEME" apply >/dev/null 2>&1
	assert_equals "light" "$(cat "$XDG_CACHE_HOME/river-theme/mode")"
}
test_mode_7am_is_light() {
	RIVER_THEME_FORCE_HOUR=7 "$RIVER_THEME" apply >/dev/null 2>&1
	assert_equals "light" "$(cat "$XDG_CACHE_HOME/river-theme/mode")"
}
test_mode_7pm_is_dark() {
	# 19:00 is the boundary -- dark starts here.
	RIVER_THEME_FORCE_HOUR=19 "$RIVER_THEME" apply >/dev/null 2>&1
	assert_equals "dark" "$(cat "$XDG_CACHE_HOME/river-theme/mode")"
}
test_mode_6am_is_dark() {
	RIVER_THEME_FORCE_HOUR=6 "$RIVER_THEME" apply >/dev/null 2>&1
	assert_equals "dark" "$(cat "$XDG_CACHE_HOME/river-theme/mode")"
}
test_mode_late_night_is_dark() {
	RIVER_THEME_FORCE_HOUR=23 "$RIVER_THEME" apply >/dev/null 2>&1
	assert_equals "dark" "$(cat "$XDG_CACHE_HOME/river-theme/mode")"
}
# Leading-zero hours must not be read as octal.
test_mode_0900_is_light() {
	RIVER_THEME_FORCE_HOUR=09 "$RIVER_THEME" apply >/dev/null 2>&1
	assert_equals "light" "$(cat "$XDG_CACHE_HOME/river-theme/mode")"
}

# --- palette generation -----------------------------------------------------

test_light_palette_written() {
	"$RIVER_THEME" apply light >/dev/null 2>&1
	assert_file_contains "$XDG_CONFIG_HOME/waybar/theme.css" "#2c6cbf"
	assert_file_contains "$XDG_CONFIG_HOME/swaync/theme.css" "#2c6cbf"
}
test_dark_palette_written() {
	"$RIVER_THEME" apply dark >/dev/null 2>&1
	assert_file_contains "$XDG_CONFIG_HOME/waybar/theme.css" "#ffb52a"
	assert_file_contains "$XDG_CONFIG_HOME/swaync/theme.css" "#ffb52a"
}
test_theme_css_defines_palette_names() {
	"$RIVER_THEME" apply dark >/dev/null 2>&1
	# Note: not named `name` -- that would clobber run_test's `local name`
	# (bash dynamic scoping) and mislabel this test in the output.
	for cname in bg bg-alt fg muted accent alert; do
		assert_file_contains "$XDG_CONFIG_HOME/waybar/theme.css" "@define-color $cname"
	done
}

# --- toggle -----------------------------------------------------------------

test_toggle_dark_to_light() {
	"$RIVER_THEME" apply dark >/dev/null 2>&1
	"$RIVER_THEME" toggle >/dev/null 2>&1
	assert_equals "light" "$(cat "$XDG_CACHE_HOME/river-theme/mode")"
}
test_toggle_light_to_dark() {
	"$RIVER_THEME" apply light >/dev/null 2>&1
	"$RIVER_THEME" toggle >/dev/null 2>&1
	assert_equals "dark" "$(cat "$XDG_CACHE_HOME/river-theme/mode")"
}

# --- mode subcommand --------------------------------------------------------

test_mode_subcommand_reports_state() {
	"$RIVER_THEME" apply light >/dev/null 2>&1
	assert_equals "light" "$("$RIVER_THEME" mode)"
}

# --- graceful degradation (no riverctl/waybar on PATH) ----------------------

test_apply_succeeds_without_compositor_tools() {
	"$RIVER_THEME" apply dark >/dev/null 2>&1
	status=$?
	assert_status 0
}

# --- river-lid arg handling -------------------------------------------------

test_river_lid_requires_output_name() {
	"$RIVER_LID" >/dev/null 2>&1
	status=$?
	assert_status 2
}
test_river_lid_noop_without_wlr_randr() {
	# wlr-randr absent on the isolated PATH -> clean no-op exit 0.
	"$RIVER_LID" eDP-1 >/dev/null 2>&1
	status=$?
	assert_status 0
}

# Install a fake wlr-randr: a query (no --output) prints the fixture; a
# set (--output ... --off/--on) is logged so we can assert what happened.
make_fake_wlr() {
	export WLR_FIXTURE="$TEST_TMPDIR/wlr_fixture"
	export WLR_LOG="$TEST_TMPDIR/wlr_log"
	: >"$WLR_LOG"
	printf '%s' "$1" >"$WLR_FIXTURE"
	cat >"$TEST_TMPDIR/bin/wlr-randr" <<'FAKE'
#!/bin/sh
if test "$1" = "--output"; then
	echo "wlr-randr $*" >> "$WLR_LOG"
	exit 0
fi
cat "$WLR_FIXTURE"
FAKE
	chmod +x "$TEST_TMPDIR/bin/wlr-randr"
}

run_lid_oneshot() {
	local lidfile="$TEST_TMPDIR/lidstate"
	printf 'state:      %s\n' "$1" >"$lidfile"
	RIVER_LID_ONESHOT=1 RIVER_LID_STATE_FILE="$lidfile" \
		"$RIVER_LID" eDP-1 >/dev/null 2>&1
}

# External connected but DISABLED + lid closed: must NOT blank the internal
# panel (that would leave no visible screen).
test_river_lid_keeps_internal_when_external_disabled() {
	make_fake_wlr 'eDP-1 "Internal"
  Enabled: yes
HDMI-A-1 "External"
  Enabled: no
'
	run_lid_oneshot closed
	if grep -q -- "--off" "$WLR_LOG"; then
		echo "  FAIL: internal panel turned off despite no enabled external"
		TEST_FAILED=1
	fi
	if ! grep -q -- "--on" "$WLR_LOG"; then
		echo "  FAIL: internal panel not kept on"
		TEST_FAILED=1
	fi
}

# External connected AND enabled + lid closed: blank the internal panel.
test_river_lid_blanks_internal_when_external_enabled() {
	make_fake_wlr 'eDP-1 "Internal"
  Enabled: yes
HDMI-A-1 "External"
  Enabled: yes
'
	run_lid_oneshot closed
	if ! grep -q -- "--off" "$WLR_LOG"; then
		echo "  FAIL: internal panel not turned off with an enabled external"
		TEST_FAILED=1
	fi
}

# Lid open with an enabled external: internal stays on.
test_river_lid_keeps_internal_when_open() {
	make_fake_wlr 'eDP-1 "Internal"
  Enabled: yes
HDMI-A-1 "External"
  Enabled: yes
'
	run_lid_oneshot open
	if grep -q -- "--off" "$WLR_LOG"; then
		echo "  FAIL: internal panel turned off while lid open"
		TEST_FAILED=1
	fi
}

# --- setup-river help -------------------------------------------------------

test_setup_river_help() {
	out="$("$SETUP_RIVER" --help 2>&1)"
	status=$?
	assert_status 0
	case "$out" in
	*"Configure a river-based Wayland desktop"*) : ;;
	*)
		echo "  FAIL: --help missing usage text"
		TEST_FAILED=1
		;;
	esac
}

run_test "river-theme has valid sh syntax" test_river_theme_syntax
run_test "river-lid has valid sh syntax" test_river_lid_syntax
run_test "setup-river has valid bash syntax" test_setup_river_syntax
run_test "midday is light mode" test_mode_midday_is_light
run_test "07:00 is light mode" test_mode_7am_is_light
run_test "19:00 is dark mode" test_mode_7pm_is_dark
run_test "06:00 is dark mode" test_mode_6am_is_dark
run_test "late night is dark mode" test_mode_late_night_is_dark
run_test "09:00 is light mode (no octal parse)" test_mode_0900_is_light
run_test "light palette written to theme.css" test_light_palette_written
run_test "dark palette written to theme.css" test_dark_palette_written
run_test "theme.css defines all palette names" test_theme_css_defines_palette_names
run_test "toggle dark -> light" test_toggle_dark_to_light
run_test "toggle light -> dark" test_toggle_light_to_dark
run_test "mode subcommand reports state" test_mode_subcommand_reports_state
run_test "apply degrades without compositor tools" test_apply_succeeds_without_compositor_tools
run_test "river-lid requires an output name" test_river_lid_requires_output_name
run_test "river-lid no-ops without wlr-randr" test_river_lid_noop_without_wlr_randr
run_test "river-lid keeps internal on when external disabled" test_river_lid_keeps_internal_when_external_disabled
run_test "river-lid blanks internal when external enabled" test_river_lid_blanks_internal_when_external_enabled
run_test "river-lid keeps internal on while lid open" test_river_lid_keeps_internal_when_open
run_test "setup-river --help prints usage" test_setup_river_help

echo
echo "$TESTS_RUN tests, $TESTS_PASSED passed, $TESTS_FAILED failed"
test "$TESTS_FAILED" -eq 0
