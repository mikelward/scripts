#!/bin/bash
# tmuxlist - list tmux sessions with useful details
#
# Prints one block per session, using the same format as autotmux's switch
# disambiguation prompt: the session name, its status, the basename of its vcs
# root and working directory, the commands running in it, and any vcs unmerged
# items.

# Reuse the enumeration and formatting helpers from autotmux.
source "$(dirname "$0")/autotmux"

# Load the user's vcs helper (best-effort) for the vcs root/unmerged fields.
test -r "$HOME/.shrc.vcs" && source "$HOME/.shrc.vcs"

first_pane_path() {
  # The working directory of a session's first pane.
  list_tmux_panes | awk -F'\t' -v n="$1" '$1 == n { print $2; exit }'
}

while IFS=$'\t' read -r session attached; do
  test -n "$session" || continue
  state="$( (test "$((attached + 0))" -gt 0 && echo attached) || echo disconnected )"
  describe_session "$session" "$(first_pane_path "$session")" "$state"
  echo
done < <(list_tmux_sessions)
