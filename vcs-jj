def cmd_map(args):
    # Check if at tip
    output = jj_output("--no-pager", "log", "--no-graph",
                       "-r", "children(@) | (children(@-) ~ @)",
                       "--template", '"x"')
    if not output:
        return cmd_base(args)
    return cmd_graph(args)


