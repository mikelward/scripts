def cmd_base(args):
    tmpl = ('if(self.contained_in("@"), '
            'if(description.first_line(), "@ " ++ change_id.shortest() ++ " " ++ description.first_line() ++ "\\n"), '
            '"* " ++ change_id.shortest() ++ " " ++ description.first_line() ++ "\\n")')
    return jj("--no-pager", "log", "--no-graph", "-r", "@|@-", "--template", tmpl, *args)


