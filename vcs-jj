def cmd_fetchtime(args):
    root = rootdir()
    if root is None:
        return 1
    fetch_head = os.path.join(root, ".jj", "repo", "store", "git", "FETCH_HEAD")
    if os.path.isfile(fetch_head):
        print(int(os.path.getmtime(fetch_head)))
        return 0
    return 1


