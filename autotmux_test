  export TMUX="/tmp/fake,1,0"
  export TMUX_S="myproject/2"
  export TMUX_PREFIX="myproject/"
  run_autotmux
  assert_status 1
  assert_output_contains "Already in tmux session"
  assert_not_called "tmux switch-client"
}

test_already_attached_exact_name_matches_prefix() {
  # A session named "myproject" (no separator) belongs to prefix "myproject/".
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="myproject"
  export TMUX_PREFIX="myproject/"
  run_autotmux
  assert_status 1
  assert_output_contains "Already in tmux session"
}

test_already_attached_mismatch_switches_to_new() {
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  export TMUX_PREFIX="myproject/"
  run_autotmux
  assert_status 0
  assert_output_contains "does not match prefix"
  assert_called "tmux switch-client -t myproject/1"
}

test_already_attached_mismatch_reuses_disconnected() {
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  export TMUX_PREFIX="myproject/"
  add_session "other/1" 1
  add_session "myproject/3" 0
  run_autotmux
  assert_status 0
  assert_called "tmux switch-client -t myproject/3"
}

# --- switch ---

test_switch_switches_client() {
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  run_autotmux switch foo
  assert_status 0
  assert_called "tmux switch-client -t foo"
}

test_switch_creates_missing_target() {
  # Switching to a session that doesn't exist creates it (detached) first.
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  run_autotmux switch foo
  assert_status 0
  assert_called "tmux new-session -d -s foo"
  assert_called "tmux switch-client -t foo"
}

test_switch_does_not_recreate_existing_target() {
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  add_session foo 0
  run_autotmux switch foo
  assert_status 0
  assert_not_called "tmux new-session"
  assert_called "tmux switch-client -t foo"
}

test_switch_resolves_path_segment() {
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  add_session "work/2" 0
  add_pane "work/2" "/home/u/sep/foo"
  run_autotmux switch sep
  assert_status 0
  assert_called "tmux switch-client -t work/2"
}

test_switch_requires_whole_segment() {
  # "sep" must not match the "separate" directory; it falls back to a new
  # session literally named "sep".
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  add_session "work/2" 0
  add_pane "work/2" "/home/u/separate/foo"
  run_autotmux switch sep
  assert_status 0
  assert_called "tmux switch-client -t sep"
}

test_switch_numeric_is_session_name() {
  # A bare number is a session name, even if a session's path contains it.
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  add_session "work/2" 0
  add_pane "work/2" "/home/u/2/foo"
  run_autotmux switch 2
  assert_status 0
  assert_called "tmux switch-client -t 2"
}

test_switch_existing_session_name_wins() {
  # An existing named session is honored even if its name is also a path segment.
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  add_session "work" 0
  add_pane "five" "/home/u/work/foo"
  run_autotmux switch work
  assert_status 0
  assert_called "tmux switch-client -t work"
}

test_switch_no_match_uses_arg() {
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  add_session "work/2" 0
  add_pane "work/2" "/home/u/other/foo"
  run_autotmux switch newname
  assert_status 0
  assert_called "tmux switch-client -t newname"
}

test_switch_prompts_on_multiple_matches() {
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  add_session "a/2" 0
  add_session "b/7" 0
  add_pane "a/2" "/home/a/sep/foo"
  add_pane "b/7" "/home/b/sep/bar"
  # Choosing option 2 selects the second session (b/7).
  run_autotmux_input 2 switch sep
  assert_status 0
  assert_output_contains "Multiple sessions match 'sep'"
  assert_called "tmux switch-client -t b/7"
}

test_switch_cancel_does_not_switch() {
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  add_session "a/2" 0
  add_session "b/7" 0
  add_pane "a/2" "/home/a/sep/foo"
  add_pane "b/7" "/home/b/sep/bar"
  # No valid selection (EOF) cancels: non-zero exit and no switch.
  run_autotmux switch sep
  [ "$status" -ne 0 ] || { echo "  FAIL: expected non-zero exit"; return 1; }
  assert_not_called "tmux switch-client"
}

test_switch_matches_vcs_unmerged() {
  # "switch abcdef" finds the session whose `vcs unmerged` lists abcdef.
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  local d="$TEST_TMPDIR/proj"
  mkdir -p "$d"
  printf 'abcdef Something\n123456 Other\n' > "$d/.unmerged"
  add_session "work/7" 0
  add_pane "work/7" "$d"
  run_autotmux switch abcdef
  assert_status 0
  assert_called "tmux switch-client -t work/7"
}

test_switch_unmerged_matches_whole_word() {
  # "abc" must not match the unmerged item "abcdef".
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  local d="$TEST_TMPDIR/proj"
  mkdir -p "$d"
  printf 'abcdef Something\n' > "$d/.unmerged"
  add_session "work/7" 0
  add_pane "work/7" "$d"
  run_autotmux switch abc
  assert_status 0
  assert_called "tmux switch-client -t abc"
}

test_switch_normalizes_target_metacharacters() {
  # An explicit target that falls back to the raw argument must have '.'/':'
  # normalized to '_', or tmux creates "my_proj" but the switch-client target
  # "my.proj" is parsed as a pane selector and the switch fails.
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  run_autotmux switch my.proj
  assert_status 0
  assert_called "tmux new-session -d -s my_proj"
  assert_called "tmux switch-client -t my_proj"
  assert_not_called "switch-client -t my\.proj"   # escape '.' (grep regex)
}

test_switch_outside_tmux_normalizes_target() {
  run_autotmux switch a:b
  assert_status 0
  assert_called "tmux new-session -s a_b"
}

test_switch_normalizes_hash_in_fallback_target() {  # '#' is normalized in a generated fallback name too.
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  run_autotmux switch 'foo#bar'
  assert_status 0
  assert_called "tmux switch-client -t foo_bar"
}

test_switch_normalizes_leading_equals() {
  # A leading '=' is tmux's exact-match modifier, so a generated "=foo" target
  # would resolve to "foo"; it must be normalized to "_foo".
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  run_autotmux switch '=foo'
  assert_status 0
  assert_called "tmux switch-client -t _foo"
}

test_sanitizes_leading_equals_prefix() {
  # A project basename starting with '=' must not produce a "=name/1" session.
  cat > "$TEST_TMPDIR/bin/rootdir" <<'ROOTDIR'
#!/bin/bash
echo "/home/u/=api"
ROOTDIR
  chmod +x "$TEST_TMPDIR/bin/rootdir"
  run_autotmux
  assert_status 0
  assert_called "tmux new-session -s _api/1"
}

test_switch_existing_hash_name_not_normalized() {
  # tmux keeps '#' in names it stores, so an existing "foo#bar" session must be
  # switched to verbatim -- normalization applies only to generated names.
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  add_session 'foo#bar' 0
  run_autotmux switch 'foo#bar'
  assert_status 0
  assert_called "tmux switch-client -t foo#bar"
  assert_not_called "switch-client -t foo_bar"
}

test_auto_switch_failure_propagates() {
  # A failed in-place switch must not be masked: with `autotmux && exit` the
  # shell would otherwise exit without having moved to the intended session.
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  export TMUX_PREFIX="myproject/"
  export TMUX_SWITCH_EXIT=3
  run_autotmux
  assert_status 3
}

test_switch_outside_tmux_attaches() {
  # With no client to switch, a switch attaches the resolved session.
  add_session foo 0
  run_autotmux switch foo
  assert_status 0
  assert_called "tmux attach-session -t foo"
  assert_not_called "tmux switch-client"
}

test_switch_outside_tmux_creates_when_missing() {
  run_autotmux switch foo
  assert_status 0
  assert_called "tmux new-session -s foo"
  assert_not_called "tmux switch-client"
}

# --- switch with no argument ---

test_switch_no_arg_switches_on_mismatch() {
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  export TMUX_PREFIX="myproject/"
  run_autotmux switch
  assert_status 0
  assert_output_contains "does not match prefix"
