}

test_switch_no_arg_errors_when_not_in_tmux() {
  export TMUX_PREFIX="myproject/"
  run_autotmux switch
  assert_status 1
  assert_output_contains "Not in a tmux session"
}

# --- tmuxlist ---

test_tmuxlist_lists_sessions() {
  local d="$TEST_TMPDIR/proj"
  mkdir -p "$d"
  echo "$TEST_TMPDIR/proj" > "$d/.vcsroot"
  printf 'abcdef Something\n' > "$d/.unmerged"
  add_session "4" 1
  add_pane "4" "$d"
  run_tmuxlist
  assert_status 0
  assert_output_contains "4"                 # session name
  assert_output_contains "●"                 # attached status icon
  assert_output_contains "proj"              # basename of vcs root / cwd
  assert_output_contains "abcdef Something"  # vcs unmerged
}

test_tmuxlist_shows_disconnected_icon() {
  add_session "5" 0
  add_pane "5" "/home/u/work"
  run_tmuxlist
  assert_status 0
  assert_output_contains "○"
}

test_tmuxlist_empty_when_no_sessions() {
  run_tmuxlist
  assert_status 0
  if [ -n "$output" ]; then
    echo "  FAIL: expected empty output, got: $output"
    return 1
  fi
}

