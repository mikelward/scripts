}

test_switch_no_arg_stays_when_matching() {
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="myproject/2"
  export TMUX_PREFIX="myproject/"
  run_autotmux switch
  assert_status 1
  assert_output_contains "Already in tmux session"
