#!/bin/bash
# Tests for autotmux

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TESTS_RUN=0
TESTS_PASSED=0
TESTS_FAILED=0

setup() {
  TEST_TMPDIR="$(mktemp -d)"
  export HOME="$TEST_TMPDIR"
  export PATH="$TEST_TMPDIR/bin:$PATH"

  mkdir -p "$TEST_TMPDIR/bin"

  # Create a fake tmux that records its calls and is backed by fixture files:
  #   .tmux_sessions - one "name<TAB>attached" row per session (for list-sessions)
  #   .tmux_panes    - one "session<TAB>path" row per pane (for list-panes -a)
  #   .tmux_dup      - session names that new-session should reject as duplicates
  #   $TMUX_S        - the current session name (for display-message -p '#S')
  cat > "$TEST_TMPDIR/bin/tmux" <<'TMUX'
#!/bin/bash
echo "tmux $*" >> "$HOME/.tmux_calls"
cmd="$1"; shift
case "$cmd" in
  list-sessions)
    cat "$HOME/.tmux_sessions" 2>/dev/null
    test -s "$HOME/.tmux_sessions" || { echo "no server running" >&2; exit 1; }
    exit 0
    ;;
  list-panes)
    if printf '%s\n' "$@" | grep -qx -- '-a'; then
      cat "$HOME/.tmux_panes" 2>/dev/null
    else
      # list-panes -t NAME -F '#{pane_current_command}': serve a generic list.
      cat "$HOME/.tmux_cmds" 2>/dev/null
    fi
    exit 0
    ;;
  display-message)
    printf '%s\n' "$TMUX_S"
    exit 0
    ;;
  attach-session)
    exit "${TMUX_ATTACH_EXIT:-0}"
    ;;
  new-session)
    # Find the -s NAME argument.
    name=
    while [ $# -gt 0 ]; do
      [ "$1" = -s ] && { name="$2"; break; }
      shift
    done
    if grep -Fxq "$name" "$HOME/.tmux_dup" 2>/dev/null; then
      echo "duplicate session: $name" >&2
      exit 1
    fi
    exit "${TMUX_NEW_EXIT:-0}"
    ;;
  switch-client)
    exit "${TMUX_SWITCH_EXIT:-0}"
    ;;
  *)
    exit 0
    ;;
esac
TMUX
  chmod +x "$TEST_TMPDIR/bin/tmux"

  # Fake rootdir that prints nothing by default (no project prefix).
  cat > "$TEST_TMPDIR/bin/rootdir" <<'ROOTDIR'
#!/bin/bash
echo ""
ROOTDIR
  chmod +x "$TEST_TMPDIR/bin/rootdir"

  # Fake vcs that reads per-directory marker files in the current directory:
  #   .vcsroot  - printed by "vcs rootdir"
  #   .unmerged - printed by "vcs unmerged"
  cat > "$TEST_TMPDIR/bin/vcs" <<'VCS'
#!/bin/bash
case "$1" in
  rootdir)  cat "$PWD/.vcsroot" 2>/dev/null ;;
  unmerged) cat "$PWD/.unmerged" 2>/dev/null ;;
esac
exit 0
VCS
  chmod +x "$TEST_TMPDIR/bin/vcs"

  # Create stub .shrc.vcs
  touch "$TEST_TMPDIR/.shrc.vcs"

  # Clean state
  unset TMUX
  unset TMUX_S
  unset TMUX_PREFIX
  unset TMUX_ATTACH_EXIT
  unset TMUX_NEW_EXIT
  unset TMUX_SWITCH_EXIT
  rm -f "$TEST_TMPDIR/.tmux_calls"
  rm -f "$TEST_TMPDIR/.tmux_sessions"
  rm -f "$TEST_TMPDIR/.tmux_panes"
  rm -f "$TEST_TMPDIR/.tmux_dup"
  rm -f "$TEST_TMPDIR/.tmux_cmds"
}

# Add a session row: name and attached count (default 0 = detached).
add_session() {
  printf '%s\t%s\n' "$1" "${2:-0}" >> "$HOME/.tmux_sessions"
}

# Add a pane row: session name and working directory.
add_pane() {
  printf '%s\t%s\n' "$1" "$2" >> "$HOME/.tmux_panes"
}

teardown() {
  rm -rf "$TEST_TMPDIR"
}

run_autotmux() {
  set +e
  output="$("$SCRIPT_DIR/autotmux" "$@" </dev/null 2>&1)"
  status=$?
  set -e
}

# Like run_autotmux, but feeds the first argument to the script on stdin.
run_autotmux_input() {
  local input="$1"; shift
  set +e
  output="$(printf '%s\n' "$input" | "$SCRIPT_DIR/autotmux" "$@" 2>&1)"
  status=$?
  set -e
}

run_tmuxlist() {
  set +e
  output="$("$SCRIPT_DIR/tmuxlist" "$@" </dev/null 2>&1)"
  status=$?
  set -e
}

assert_status() {
  local expected=$1
  if [ "$status" -ne "$expected" ]; then
    echo "  FAIL: expected exit status $expected, got $status"
    echo "  output: $output"
    TEST_FAILED=1
    return 1
  fi
}

assert_output_contains() {
  if [[ "$output" != *"$1"* ]]; then
    echo "  FAIL: output does not contain '$1'"
    echo "  output: $output"
    TEST_FAILED=1
    return 1
  fi
}

assert_called() {
  if ! grep -q "$1" "$HOME/.tmux_calls" 2>/dev/null; then
    echo "  FAIL: expected call '$1' not found"
    echo "  calls: $(cat "$HOME/.tmux_calls" 2>/dev/null)"
    TEST_FAILED=1
    return 1
  fi
}

assert_not_called() {
  if grep -q "$1" "$HOME/.tmux_calls" 2>/dev/null; then
    echo "  FAIL: did not expect call '$1'"
    echo "  calls: $(cat "$HOME/.tmux_calls" 2>/dev/null)"
    TEST_FAILED=1
    return 1
  fi
}

run_test() {
  local name="$1"
  local func="$2"
  TESTS_RUN=$((TESTS_RUN + 1))
  setup
  # TEST_FAILED catches asserts that fail mid-test: running "$func" as an `if`
  # condition disables `set -e` inside it, so a failed assert that isn't the
  # last statement would otherwise be ignored.
  TEST_FAILED=
  if "$func" && test -z "$TEST_FAILED"; then
    echo "ok $TESTS_RUN $name"
    TESTS_PASSED=$((TESTS_PASSED + 1))
  else
    echo "not ok $TESTS_RUN $name"
    TESTS_FAILED=$((TESTS_FAILED + 1))
  fi
  teardown
}

# --- passthrough ---

test_passthrough_to_tmux() {
  run_autotmux list-keys
  assert_status 0
  assert_called "tmux list-keys"
}

test_passthrough_preserves_args() {
  run_autotmux kill-session -t foo
  assert_status 0
  assert_called "tmux kill-session -t foo"
}

# --- startup: attach / create ---

test_creates_session_1() {
  run_autotmux
  assert_status 0
  assert_called "tmux new-session -s 1"
  assert_output_contains "Creating tmux session 1"
}

test_attaches_disconnected_first() {
  add_session 2 1   # attached
  add_session 3 0   # disconnected
  run_autotmux
  assert_status 0
  assert_called "tmux attach-session -t 3"
  assert_output_contains "Attaching tmux session 3"
}

test_skips_existing_sessions() {
  add_session 1 1
  add_session 2 1
  run_autotmux
  assert_status 0
  assert_called "tmux new-session -s 3"
  assert_output_contains "Creating tmux session 3"
}

test_attaches_disconnected_with_space_in_name() {
  # autotmux derives the prefix from the project basename, which may contain a
  # space, so a generated name like "my project/1" must round-trip whole rather
  # than splitting into "my" and "project/1".
  export TMUX_PREFIX="my project/"
  add_session "my project/1" 0
  run_autotmux
  assert_status 0
  assert_called "tmux attach-session -t my project/1"
  assert_output_contains "Attaching tmux session my project/1"
}

test_creates_next_number_with_space_in_name() {
  # Building the set of taken names must keep whitespace names intact, or the
  # attached "my project/1" wouldn't be recognised and would be recreated.
  export TMUX_PREFIX="my project/"
  add_session "my project/1" 1   # attached: can't reuse, must pick next number
  run_autotmux
  assert_status 0
  assert_called "tmux new-session -s my project/2"
}

test_sanitizes_prefix_metacharacters() {
  # A project basename with '.', ':' or '#' must be normalized to '_' when
  # building the prefix, since tmux rewrites those characters in stored session
  # names and treats them specially (target metacharacters / format expansion).
  cat > "$TEST_TMPDIR/bin/rootdir" <<'ROOTDIR'
#!/bin/bash
echo "/home/u/a.b:c#d"
ROOTDIR
  chmod +x "$TEST_TMPDIR/bin/rootdir"
  run_autotmux
  assert_status 0
  assert_called "tmux new-session -s a_b_c_d/1"
}

test_reuses_separatorless_session() {
  # A detached session named exactly like the bare prefix (no separator) belongs
  # to the project, so startup reuses it instead of creating "myproject/1".
  export TMUX_PREFIX="myproject/"
  add_session "myproject" 0
  run_autotmux
  assert_status 0
  assert_called "tmux attach-session -t myproject"
  assert_output_contains "Attaching tmux session myproject"
  assert_not_called "tmux new-session"
}

test_mismatch_switch_reuses_separatorless_session() {
  # The no-arg/mismatch switch path reuses the separatorless session too.
  export TMUX="/tmp/fake,1,0"
  export TMUX_S="other/1"
  export TMUX_PREFIX="myproject/"
  add_session "other/1" 1
  add_session "myproject" 0
  run_autotmux
  assert_status 0
  assert_called "tmux switch-client -t myproject"
}

test_uses_prefix() {
  export TMUX_PREFIX="myproject/"
  run_autotmux
  assert_status 0
  assert_called "tmux new-session -s myproject/1"
}

test_returns_nonzero_on_attach_failure() {
  add_session 3 0
  export TMUX_ATTACH_EXIT=1
  run_autotmux
  assert_status 1
}

test_preserves_attach_exit_code() {
  add_session 3 0
  export TMUX_ATTACH_EXIT=42
  run_autotmux
  assert_status 42
}

test_retries_on_duplicate_session() {
  # new-session for "1" reports a duplicate, so autotmux tries "2".
  echo "1" > "$HOME/.tmux_dup"
  run_autotmux
  assert_status 0
  assert_called "tmux new-session -s 1"
  assert_called "tmux new-session -s 2"
  assert_output_contains "Creating tmux session 2"
  assert_output_contains "duplicate session"
}

test_propagates_real_new_session_failure() {
  # A non-zero new-session exit with no duplicate message must propagate.
  export TMUX_NEW_EXIT=7
  run_autotmux
  assert_status 7
  assert_called "tmux new-session -s 1"
  assert_not_called "tmux new-session -s 2"
}

